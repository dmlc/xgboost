[build-system]
requires = ["scikit-build-core>=0.10.0"]
build-backend = "scikit_build_core.build"

[project]
name = "{{ name }}"
description = "XGBoost Python Package"
readme = { file = "README.rst", content-type = "text/x-rst" }
authors = [
    { name = "Hyunsu Cho", email = "chohyu01@cs.washington.edu" },
    { name = "Jiaming Yuan", email = "jm.yuan@outlook.com" }
]
version = "3.4.0-dev"
requires-python = ">=3.12"
license = { text = "Apache-2.0" }
classifiers = [
    "License :: OSI Approved :: Apache Software License",
    "Development Status :: 5 - Production/Stable",
    "Operating System :: OS Independent",
    "Typing :: Typed",
    "Programming Language :: Python",
    "Programming Language :: Python :: 3",
    "Programming Language :: Python :: 3.12",
    "Programming Language :: Python :: 3.13",
]
dependencies = [
    "xgboost=={{ version }}",
]

# Stub packages (e.g. xgboost-cu12) carry no code — they only redeclare
# `xgboost` as a runtime dependency so users who `pip install xgboost-cu12`
# pull in the canonical `xgboost` package. The CMake project is a no-op.
[tool.scikit-build]
cmake.version = ">=3.18"
cmake.source-dir = "stub-cmake"
build-dir = "build/{wheel_tag}"
ninja.make-fallback = true
wheel.py-api = "py3"
wheel.platlib = false
wheel.packages = []
